kk˚˚˚˚˚of
    L = img_lab[:, :, 0]
    A = img_lab[:, :, 1]
    B = img_lab[:, :, 2]

    shadow_lift = float(np.clip(0.04 + stats['shadow_pct'] * 0.25, 0.03, 0.12))
    mid_target  = float(np.clip(0.50 + (0.45 - stats['mean_lum']) * 0.60, 0.42, 0.62))
    hi_compress = float(np.clip(0.85 - stats['highlight_pct'] * 0.30, 0.70, 0.95))

    L_norm = L / 255.0
    L_new = np.interp(L_norm,
        [0.00, 0.05, 0.20, 0.40, 0.60, 0.80, hi_compress, 1.0],
        [0.00, shadow_lift, shadow_lift+0.17, mid_target-0.08,
         mid_target+0.08, mid_target+0.22, hi_compress, min(hi_compress+0.04, 1.0)]
    )
    L = np.clip(L_new * 255.0, 0, 255)

    blown_threshold = float(np.clip(210 + (1.0 - stats['highlight_pct'] * 5) * 20, 195, 235))
    blown_mask = np.clip((L - blown_threshold) / 40.0, 0, 1)
    L = L * (1 - blown_mask) + (blown_threshold + (L - blown_threshold) * 0.20) * blown_mask
    L = np.clip(L, 0, 255)

    contrast_strength = float(np.clip(0.35 - stats['std_lum'] * 0.5, 0.10, 0.35))
    blurred = cv2.GaussianBlur(L, (0, 0), 60.0)
    detail = L - blurred
    midtone_mask = np.clip(np.sin(np.pi * np.clip((L / 255.0 - 0.10) / 0.75, 0, 1)), 0, 1) * contrast_strength
    L = np.clip(L + detail * midtone_mask, 0, 255)

    white_threshold = float(np.clip(0.78 + stats['mean_lum'] * 0.12, 0.78, 0.90))
    white_push = np.clip((L / 255.0 - white_threshold) / (1.0 - white_threshold), 0, 1)
    L = np.clip(L + white_push * (250 - L) * 0.60, 0, 255)

    if stats['shadow_pct'] > 0.05:
        black_threshold = float(np.clip(0.18 + stats['p5'] * 0.5, 0.12, 0.28))
        black_pull = np.clip(1.0 - (L / 255.0) / black_threshold, 0, 1)
        black_strength = float(np.clip(stats['shadow_pct'] * 1.2, 0.15, 0.40))
        L = np.clip(L * (1.0 - black_pull * black_strength), 0, 255)

    bgr_f = img_uint8.astype(np.float32) / 255.0
    current_sat = float(np.mean(np.std(bgr_f, axis=2)))
    sat_boost_base = float(np.clip(1.15 + (0.12 - current_sat) * 2.0, 1.05, 1.35))
    lum_norm = L / 255.0
    sat_curve = 1.0 + (sat_boost_base - 1.0) * np.sin(np.pi * np.clip(lum_norm, 0, 1))
    A = np.clip((A - 128) * sat_curve + 128, 0, 255)
    B = np.clip((B - 128) * sat_curve + 128, 0, 255)

    mean_a = float(np.mean(A)) - 128
    mean_b = float(np.mean(B)) - 128
    A = np.clip(A + np.clip(-mean_a * 0.4, -8, 8), 0, 255)
    B = np.clip(B + np.clip(-mean_b * 0.4 + 2.0, -8, 8), 0, 255)

    img_lab[:, :, 0] = L
    img_lab[:, :, 1] = A
    img_lab[:, :, 2] = B

    result = cv2.cvtColor(img_lab.astype(np.uint8), cv2.COLOR_LAB2BGR).astype(np.float32) / 255.0
    return np.clip(result * 255, 0, 255).astype(np.uint8)
